# Game backend (Fastify + Socket.IO). In dev it also reads ../app/.env so you
# usually only need overrides here.

# Port/host the backend listens on
SERVER_PORT="4000"
SERVER_HOST="0.0.0.0"

# Browser origins allowed to call the backend (comma-separated). The Next dev server:
CORS_ORIGINS="http://localhost:3000"

# The following are normally inherited from ../app/.env in dev — set them here for
# a standalone/prod run:
# AUTH_SECRET must match the Next app so JWTs verify
AUTH_SECRET=""
DATABASE_URL="postgresql://phiencho:phiencho@localhost:5432/phiencho"
# Enables cross-instance socket fan-out + distributed locks (optional in single-replica dev)
REDIS_URL="redis://localhost:6379"
# SMTP_*, etc. are read from the environment as in the Next app.
