# Database (Postgres — use docker-compose or Neon)
DATABASE_URL="postgresql://phiencho:phiencho@localhost:5432/phiencho"
DIRECT_URL="postgresql://phiencho:phiencho@localhost:5432/phiencho"

# Migrations (run manually before deploy — not on container start):
#   docker compose up -d db && bun run db:migrate

# Auth.js (NextAuth v5). Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=""
# Public base URL for email links (verify/reset). Use production URL in prd.
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Brevo SMTP (Settings → SMTP & API → SMTP tab in Brevo dashboard)
# SMTP_USER = the "SMTP login" email shown on that page (NOT your sender address)
# SMTP_PASS = an SMTP key (xsmtpsib-...), NOT a REST API key or account password
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# Must match a verified sender in Brevo (Senders tab)
MAIL_FROM="Thanh Long Market <noreply@yourdomain.com>"

# Realtime fan-out (optional; in-memory bus used when empty)
REDIS_URL=""

# Cloudflare R2 (avatar uploads, optional)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# Google Gemini keys (add as many GEMINI_KEY_<n> as you have)
GEMINI_KEY_1=""
GEMINI_KEY_2=""
GEMINI_KEY_3=""
